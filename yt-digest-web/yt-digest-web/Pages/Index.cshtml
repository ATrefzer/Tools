@page
@model IndexModel
@{ ViewData["Title"] = "Zusammenfassung"; }

<h2 class="mb-4">YouTube Video zusammenfassen</h2>

<form method="post" id="summarizeForm">
    <div class="mb-3">
        <label for="url" class="form-label">YouTube-URL</label>
        <input type="url" id="url" name="VideoUrl" value="@Model.VideoUrl"
               class="form-control" placeholder="https://www.youtube.com/watch?v=..." required />
    </div>
    <div class="mb-3">
        <label for="lang" class="form-label">Sprache</label>
        <select id="lang" name="Lang" class="form-select">
            <option value="de">Deutsch</option>
            <option value="en">Englisch</option>
        </select>
    </div>
    <div class="d-flex align-items-center gap-3">
        <button type="submit" id="submitBtn" class="btn btn-primary">Zusammenfassen</button>
        <span id="loadingMsg" class="text-muted" style="display:none">
            <span class="spinner-border spinner-border-sm me-1"></span>
            Wird verarbeitet, bitte warten...
        </span>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-danger mt-4">@Model.Error</div>
}

@if (!string.IsNullOrEmpty(Model.SummaryHtml))
{
    <hr class="mt-4" />
    <div class="mt-3">
        @Html.Raw(Model.SummaryHtml)
    </div>
}

<script>
    document.getElementById('summarizeForm').addEventListener('submit', function () {
        document.getElementById('submitBtn').disabled = true;
        document.getElementById('loadingMsg').style.display = 'inline';
    });
</script>
