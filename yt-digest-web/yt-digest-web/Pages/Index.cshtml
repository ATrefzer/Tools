@page
@model IndexModel
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <title>yt-digest</title>
</head>
<body>
    <h1>YouTube Video zusammenfassen</h1>

    <form method="post" id="summarizeForm">
        <div>
            <label for="url">YouTube-URL</label>
            <input type="url" id="url" name="VideoUrl" value="@Model.VideoUrl" required />
        </div>
        <div>
            <label for="lang">Sprache</label>
            <select id="lang" name="Lang">
                <option value="de">Deutsch</option>
                <option value="en">Englisch</option>
            </select>
        </div>
        <button type="submit" id="submitBtn">Zusammenfassen</button>
        <span id="loadingMsg" style="display:none">Wird verarbeitet, bitte warten...</span>
    </form>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <hr />
        <p style="color:red">@Model.Error</p>
    }

    @if (!string.IsNullOrEmpty(Model.SummaryHtml))
    {
        <hr />
        <h2>Zusammenfassung</h2>
        @Html.Raw(Model.SummaryHtml)
    }

    <script>
        document.getElementById('summarizeForm').addEventListener('submit', function () {
            document.getElementById('submitBtn').disabled = true;
            document.getElementById('loadingMsg').style.display = 'inline';
        });
    </script>
</body>
</html>
